{
  "logger": {
    "level": "info",
    "timestamp": false
  },
  "esclient": {
    "apiVersion": "7.5",
    "hosts": [{ "host": "elasticsearch" }]
  },
  "elasticsearch": {
    "settings": {
      "index": {
        "refresh_interval": "10s",
        "number_of_replicas": "0",
        "number_of_shards": "1"
      }
    }
  },
  "api": {
    "services": {
      "placeholder": { "url": "http://placeholder:4100" },
      "pip": { "url": "http://pip:4200" },
      "libpostal": { "url": "http://libpostal:4400" }
    }
  },
  "imports": {
    "adminLookup": {
      "enabled": true
    },
    "openstreetmap": {
      "leveldbpath": "/tmp",
      "datapath": "/data/openstreetmap",
      "import": [{ "filename": "vietnam-latest.osm.pbf" }]
    },
    "csv": {
      "datapath": "/data/custom-addresses"
    },
    "polyline": {
      "datapath": "/data/polylines",
      "files": ["extract.0sv"]
    },
    "whosonfirst": {
      "datapath": "/data/whosonfirst",
      "sqlite": true,
      "importPostalcodes": true,
      "countryCode": "VN"
    }
  }
}
