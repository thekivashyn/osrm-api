PORT=8080
HOST=127.0.0.1
OSRM_URL=http://127.0.0.1:5050
OSRM_MOTOR_URL=http://127.0.0.1:5051
PELIAS_URL=http://127.0.0.1:4000
# Dev: use .env.development → remote server Pelias (no local Pelias on Mac)
GEOCODE_USER_AGENT=routing-api-internal/1.0 (ops@yourdomain.com)
GEOCODE_CACHE_TTL_MS=900000
ROUTE_CACHE_TTL_MS=1800000
# Duration multipliers on OSRM static ETA (per vehicle type)
ROUTING_DURATION_FACTOR_CAR=1.25
ROUTING_DURATION_FACTOR_MOTORBIKE=0.85
