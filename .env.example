# Production / staging — copy to `.env` on the server.
# Local dev: `bun run dev` loads `.env.development` (public OSM geocoding) instead.

PORT=8080
OSRM_URL=http://localhost:5050
OSRM_MOTOR_URL=http://localhost:5051
NOMINATIM_URL=http://localhost:9091
GEOCODE_USER_AGENT=routing-api-internal/1.0 (ops@yourdomain.com)
GEOCODE_CACHE_TTL_MS=300000
ROUTE_CACHE_TTL_MS=600000
# Duration multipliers on OSRM static ETA (per vehicle type)
ROUTING_DURATION_FACTOR_CAR=1.25
ROUTING_DURATION_FACTOR_MOTORBIKE=0.85
