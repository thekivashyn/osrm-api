# Loaded automatically when running `bun run dev` (NODE_ENV=development).
# Geocoding uses public Nominatim — no local Nominatim Docker required.
# Production (`bun run start`) uses `.env` with self-hosted Nominatim instead.

PORT=8080
OSRM_URL=http://localhost:5050
OSRM_MOTOR_URL=http://localhost:5051
NOMINATIM_URL=https://nominatim.openstreetmap.org
GEOCODE_USER_AGENT=routing-api-dev/1.0 (dev@localhost)
ROUTING_DURATION_FACTOR_CAR=1.25
ROUTING_DURATION_FACTOR_MOTORBIKE=0.85
