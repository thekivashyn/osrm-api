# Defaults for `bun run dev` — overridden by `.env` when present (see package.json).
# Geocoding fallback: public Nominatim (no local Docker). Set NOMINATIM_URL in `.env` for prod server.

PORT=8080
OSRM_URL=http://localhost:5050
OSRM_MOTOR_URL=http://localhost:5051
NOMINATIM_URL=https://nominatim.openstreetmap.org
GEOCODE_USER_AGENT=routing-api-dev/1.0 (dev@localhost)
ROUTING_DURATION_FACTOR_CAR=1.25
ROUTING_DURATION_FACTOR_MOTORBIKE=0.85
