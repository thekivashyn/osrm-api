{
  "name": "routing-api",
  "version": "1.0.0",
  "description": "Self-hosted routing API powered by OSRM",
  "type": "module",
  "scripts": {
    "dev": "sh scripts/dev-all.sh",
    "dev:api": "NODE_ENV=development bun --env-file=.env.development --env-file=.env run --watch server.ts",
    "dev:web": "pnpm --dir web dev",
    "build:web": "pnpm --dir web build",
    "dev:remote": "bun --env-file=.env.development.remote run --watch server.ts",
    "dev:remote:tunnel": "bun --env-file=.env.development.remote-tunnel run --watch server.ts",
    "start": "bun --env-file=.env run server.ts",
    "test": "bun test",
    "test:8080": "bun run scripts/smoke-8080.ts",
    "osrm:prepare": "sh scripts/prepare-osrm.sh",
    "osrm:update": "sh scripts/update-osrm-map.sh",
    "osrm:rebuild": "docker compose stop osrm && docker compose rm -f osrm && docker compose up osrm -d && docker logs -f osrm",
    "osrm:up": "docker compose up osrm -d",
    "osrm:down": "docker compose down",
    "osrm:logs": "docker logs -f osrm",
    "pelias:import": "sh scripts/pelias-import.sh",
    "pelias:overture": "sh scripts/overture-places.sh",
    "pelias:up": "sh scripts/pelias-up.sh",
    "pelias:down": "cd pelias/vietnam && ../../.pelias-docker/pelias compose down",
    "pelias:logs": "cd pelias/vietnam && ../../.pelias-docker/pelias compose logs -f api",
    "geo:up": "sh scripts/geo-up.sh",
    "geo:down": "docker compose down",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.2.0",
    "elysia": "^1.2.25"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.3"
  }
}
